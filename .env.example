# Copy this file to .env and fill in your values. Everything is optional —
# the app runs fully in "dev mode" without any of these.

# Data storage: without these set, the app stores data/* as local JSON
# files. That ONLY works when the filesystem is writable and persistent
# (i.e. running locally) — it does NOT work when deployed to Vercel, since
# Vercel's deployed filesystem is read-only and wiped between invocations.
# For a Vercel deployment, add an Upstash Redis integration from the Vercel
# Marketplace (Storage tab in your project) — it injects the right vars
# automatically. Depending on which integration flavor you pick, that's
# either UPSTASH_REDIS_REST_URL/TOKEN or KV_REST_API_URL/TOKEN — the app
# accepts either pair, so just leave whichever Vercel actually set. Locally,
# leave both blank to keep using JSON files.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Image uploads (admin dashboard "Add photos"): without this set, uploads
# save straight to public/img/products/, which works locally but NOT on
# Vercel (same read-only-filesystem issue as above). For a Vercel
# deployment, add a Blob store from the Storage tab in your project — it
# injects BLOB_READ_WRITE_TOKEN automatically.
BLOB_READ_WRITE_TOKEN=

# Resend API key for real email delivery (https://resend.com).
# Without it, emails are logged to the console and OTP codes are shown in the UI.
RESEND_API_KEY=re_your_resend_api_key_here

# The "from" address used for outgoing email.
EMAIL_FROM=Beautique <angelina.abinader@gmail.com>

# Invite code required to create an admin account from the sign-up form.
ADMIN_INVITE_CODE=BEAUTIQUE-ADMIN

# Server port (defaults to 3000).
PORT=3000
