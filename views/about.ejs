<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="container page-head">
    <span class="eyebrow">Our story</span>
    <h1>Beauty, made effortless.</h1>
    <p class="lead">Beautique was created for people who want beauty products that feel luxurious, ethical, and effortless — all at once.</p>
  </div>

  <section class="container" style="padding-bottom: 40px;">
    <div class="grid grid-2" style="align-items: center;">
      <div>
        <h2 style="font-size: 30px;">Modern formulas, everyday practicality</h2>
        <p style="color: var(--ink-soft);">We blend clean, small-batch formulas with everyday practicality so you can build a routine that enhances your natural glow — not one that hides it.</p>
        <p style="color: var(--ink-soft);">Every product in our collection is chosen by hand, tested with love, and backed by our 30-day happiness guarantee.</p>
        <a class="btn btn-primary" href="/shop" style="margin-top: 8px;">Explore the collection</a>
      </div>
      <div class="grid grid-2">
        <% showcase.forEach(function(product, i) { %>
          <div class="product-art reveal" style="--tone: <%= product.tone %>; <%= i === 1 ? 'transform: translateY(18px);' : '' %>">
            <% if (product.images && product.images.length) { %>
              <img class="art-photo" src="<%= product.images[0] %>" alt="<%= product.name %>" loading="lazy">
            <% } else { %>
              <span class="art-emoji"><%= product.emoji %></span>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="container section" style="padding-top: 40px;">
    <div class="section-head">
      <div>
        <span class="eyebrow">What we stand for</span>
        <h2>Why customers love us</h2>
      </div>
    </div>
    <div class="grid grid-3">
      <div class="card reveal">
        <span style="font-size: 34px; color: var(--primary);"><%- icon('leaf') %></span>
        <h3 style="font-size: 20px; margin-top: 12px;">Vegan &amp; cruelty-free</h3>
        <p class="text-muted" style="font-size: 14.5px; margin: 0;">Every formula is 100% vegan and never tested on animals. No exceptions, ever.</p>
      </div>
      <div class="card reveal">
        <span style="font-size: 34px; color: var(--primary);"><%- icon('heart') %></span>
        <h3 style="font-size: 20px; margin-top: 12px;">Thoughtfully curated</h3>
        <p class="text-muted" style="font-size: 14.5px; margin: 0;">A small collection of essentials that work beautifully alone — and even better together.</p>
      </div>
      <div class="card reveal">
        <span style="font-size: 34px; color: var(--primary);"><%- icon('box') %></span>
        <h3 style="font-size: 20px; margin-top: 12px;">Fast &amp; easy</h3>
        <p class="text-muted" style="font-size: 14.5px; margin: 0;">Free shipping over $50, delivery within 48 hours, and easy 30-day returns.</p>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
