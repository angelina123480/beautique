<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <section class="container section">
    <div class="auth-wrap">
      <div class="text-center" style="margin-bottom: 26px;">
        <span class="eyebrow">Welcome to Beautique</span>
        <h1 style="font-size: 34px;">Your account</h1>
        <p class="text-muted">Sign in to track orders, save your address, and review products.</p>
      </div>

      <div class="card" style="padding: 32px;">
        <div id="auth-step">
          <div class="auth-tabs" role="tablist">
            <button type="button" class="auth-toggle is-active" data-mode="signin">Sign in</button>
            <button type="button" class="auth-toggle" data-mode="signup">Create account</button>
          </div>

          <% if (googleError) { %>
            <div class="form-status is-error" style="margin-bottom: 14px;"><%= googleError %></div>
          <% } %>

          <% if (googleEnabled) { %>
            <a href="/auth/google" class="btn btn-google btn-block">
              <svg viewBox="0 0 48 48" width="18" height="18" aria-hidden="true">
                <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.9 32.9 29.4 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6 29.6 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.5z"/>
                <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 15.9 18.9 13 24 13c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6 29.6 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
                <path fill="#4CAF50" d="M24 44c5.5 0 10.4-1.9 14.3-5.1l-6.6-5.4C29.6 35.3 26.9 36 24 36c-5.4 0-9.9-3.1-11.3-7.9l-6.6 5.1C9.6 39.7 16.2 44 24 44z"/>
                <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.5-2.3 4.6-4.3 6l6.6 5.4C41.4 36.9 44 31.1 44 24c0-1.3-.1-2.7-.4-3.5z"/>
              </svg>
              Continue with Google
            </a>
            <div class="auth-divider"><span>or</span></div>
          <% } %>

          <form id="auth-form" novalidate>
            <div class="field" id="field-name" style="display:none;">
              <label for="auth-name">Full name</label>
              <input id="auth-name" type="text" placeholder="Jane Glow" autocomplete="name">
            </div>
            <div class="field">
              <label for="auth-email">Email address</label>
              <input id="auth-email" type="email" placeholder="you@example.com" autocomplete="email" required>
            </div>
            <div class="field">
              <label for="auth-password">Password</label>
              <div class="password-field">
                <input id="auth-password" type="password" placeholder="••••••••" autocomplete="current-password" required>
                <button type="button" class="password-toggle" data-target="auth-password" aria-label="Show password"><%- icon('eye') %></button>
              </div>
              <p id="password-hint" class="text-muted" style="display:none; margin-top:6px; font-size:12.5px;">At least 8 characters, with an uppercase letter, a lowercase letter, a number, and a symbol.</p>
              <a href="#" id="auth-forgot-link" class="text-muted" style="display:block; margin-top:6px; font-size:13px; text-align:right;">Forgot password?</a>
            </div>
            <div class="field" id="field-role" style="display:none;">
              <label for="auth-role">Account type</label>
              <select id="auth-role">
                <option value="client">Client — shop &amp; order</option>
                <option value="admin">Admin — manage the store</option>
              </select>
            </div>
            <div class="field" id="field-invite" style="display:none;">
              <label for="auth-invite">Admin invite code</label>
              <input id="auth-invite" type="text" placeholder="Ask the store owner for the code">
            </div>
            <button class="btn btn-primary btn-block" type="submit" id="auth-submit">Sign in</button>
          </form>
        </div>

        <div id="otp-step" style="display:none;">
          <div class="text-center">
            <span style="font-size: 40px; color: var(--primary);"><%- icon('mail') %></span>
            <h3 style="font-size: 22px; margin-top: 8px;">Check your inbox</h3>
            <p class="text-muted" style="font-size: 14.5px;">We sent a 6-digit code to <strong id="otp-email-label"></strong>. It expires in 10 minutes.</p>
          </div>
          <div class="otp-inputs" id="otp-inputs">
            <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 1">
            <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 2">
            <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 3">
            <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 4">
            <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 5">
            <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 6">
          </div>
          <div id="dev-otp-note" class="dev-note" style="display:none;"></div>
          <button class="btn btn-primary btn-block" type="button" id="otp-submit" style="margin-top: 16px;">Verify code</button>
          <p class="text-center" style="margin-top: 14px; font-size: 14px;">
            Didn't get it? <a href="#" id="otp-resend">Resend code</a> · <a href="#" id="otp-back">Start over</a>
          </p>
        </div>

        <div id="forgot-step" style="display:none;">
          <div class="text-center">
            <span style="font-size: 40px; color: var(--primary);"><%- icon('lock') %></span>
            <h3 style="font-size: 22px; margin-top: 8px;">Reset your password</h3>
            <p class="text-muted" style="font-size: 14.5px;" id="forgot-intro">Enter your email and we'll send you a reset code.</p>
          </div>

          <div class="field" id="forgot-email-field">
            <label for="forgot-email">Email address</label>
            <input id="forgot-email" type="email" placeholder="you@example.com" autocomplete="email">
          </div>
          <button class="btn btn-primary btn-block" type="button" id="forgot-send">Send reset code</button>

          <div id="forgot-reset-fields" style="display:none;">
            <div class="otp-inputs" id="reset-otp-inputs">
              <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 1">
              <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 2">
              <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 3">
              <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 4">
              <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 5">
              <input type="text" inputmode="numeric" maxlength="1" aria-label="Digit 6">
            </div>
            <div id="forgot-dev-otp-note" class="dev-note" style="display:none;"></div>
            <div class="field" style="margin-top: 14px;">
              <label for="forgot-password">New password</label>
              <div class="password-field">
                <input id="forgot-password" type="password" placeholder="••••••••" autocomplete="new-password">
                <button type="button" class="password-toggle" data-target="forgot-password" aria-label="Show password"><%- icon('eye') %></button>
              </div>
              <p class="text-muted" style="margin-top:6px; font-size:12.5px;">At least 8 characters, with an uppercase letter, a lowercase letter, a number, and a symbol.</p>
            </div>
            <button class="btn btn-primary btn-block" type="button" id="forgot-submit" style="margin-top: 16px;">Reset password</button>
          </div>

          <p class="text-center" style="margin-top: 14px; font-size: 14px;">
            <a href="#" id="forgot-back">Back to sign in</a>
          </p>
        </div>

        <div class="form-status" id="auth-status" role="status"></div>
      </div>

      <% if (devMail) { %>
        <p class="text-muted text-center" style="font-size: 13px; margin-top: 16px;">
          Email delivery is not configured (no <code>RESEND_API_KEY</code>), so verification codes are shown right here in dev mode.
        </p>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer', { pageScript: 'auth' }) %>
</body>
</html>
