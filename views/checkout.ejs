<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body data-signed-in="<%= user ? '1' : '' %>">
  <%- include('partials/header') %>

  <div class="container page-head">
    <span class="eyebrow">Almost there</span>
    <h1>Checkout</h1>
    <p class="lead">Review your bag and complete your order.</p>
  </div>

  <section class="container" style="padding-bottom: 72px;">
    <div class="checkout-layout" id="checkout-layout">
      <div class="card" id="checkout-main">
        <h3 style="font-size: 22px;">Your bag</h3>
        <div id="checkout-items"></div>

        <div id="checkout-form-area">
          <hr class="divider">
          <h3 style="font-size: 22px;">Delivery</h3>
          <div class="field">
            <label for="checkout-address">Delivery address</label>
            <input id="checkout-address" type="text" placeholder="Street, city, Lebanon"
                   value="<%= user && user.address ? user.address : '' %>">
            <p class="text-muted" style="font-size: 12px; margin-top: 6px;">We currently deliver within Lebanon only.</p>
          </div>

          <h3 style="font-size: 22px; margin-top: 26px;">Payment</h3>
          <div class="pay-options">
            <label class="pay-option is-selected">
              <input type="radio" name="paymentMethod" value="online" checked>
              <span class="pay-title"><%- icon('card') %> Pay online</span>
              <span class="pay-sub">Secure card payment</span>
            </label>
            <label class="pay-option">
              <input type="radio" name="paymentMethod" value="delivery">
              <span class="pay-title"><%- icon('box') %> Pay on delivery</span>
              <span class="pay-sub">Cash or card at your door</span>
            </label>
          </div>
        </div>
      </div>

      <div>
        <div class="card" id="checkout-summary-card">
          <h3 style="font-size: 22px;">Summary</h3>
          <div id="checkout-summary"></div>
          <% if (user) { %>
            <div class="reward-toggle" style="display:block;">
              <strong style="display:block; margin-bottom:8px; font-size:13.5px;">Have a discount code?</strong>
              <% if (unusedCodes.length) { %>
                <div id="discount-code-chips" style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px;">
                  <% unusedCodes.forEach(function(c) { %>
                    <button type="button" class="chip" data-fill-code="<%= c.code %>"><%= c.code %> · -<%= c.discount %>%</button>
                  <% }); %>
                </div>
              <% } %>
              <div style="display:flex; gap:8px;">
                <input type="text" id="discount-code-input" placeholder="Enter code" style="flex:1; padding:10px 14px; border-radius:999px; border:1.5px solid var(--border); font: inherit;">
                <button type="button" class="btn btn-soft btn-sm" id="discount-code-apply">Apply</button>
              </div>
              <div class="form-status" id="discount-code-status" style="margin-top:6px;"></div>
            </div>
          <% } %>
          <% if (!user) { %>
            <div class="notice" style="margin-bottom: 14px;">
              Please <a href="/auth">sign in</a> to place your order — it only takes a minute and lets you track everything.
            </div>
          <% } %>
          <button class="btn btn-primary btn-block" id="place-order" type="button" <%= user ? '' : 'disabled' %>>Place order</button>
          <div class="form-status" id="checkout-status"></div>
          <p class="text-muted" style="font-size: 12.5px; margin-top: 12px;"><%- icon('lock') %> Your details are safe with us. Free shipping applies automatically over $50.</p>
        </div>
        <a class="btn btn-ghost btn-block" href="/shop" style="margin-top: 14px;">← Continue shopping</a>
      </div>
    </div>
  </section>

  <script>
    /* Unused discount codes for this signed-in user, so checkout.js can
       validate and preview the discount client-side without a round trip.
       The server re-validates independently when the order is placed. */
    window.CHECKOUT_DISCOUNT_CODES = <%- JSON.stringify(unusedCodes) %>;
  </script>

  <%- include('partials/footer', { pageScript: 'checkout' }) %>
</body>
</html>
