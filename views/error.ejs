<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <section class="container">
    <div class="error-hero">
      <div class="error-code"><%= status || 500 %></div>
      <h1 style="font-size: 30px;"><%= status === 404 ? 'This page wandered off…' : 'Something went wrong' %></h1>
      <p class="lead" style="margin: 0 auto 26px;"><%= message %></p>
      <div style="display:flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/shop">Browse the shop</a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
