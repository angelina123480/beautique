<%
  /* Not every shade needs its own photo for this to work — shades without
     one are simply skipped, so the cycle just uses whichever do have one. */
  var cardShadePhotos = (product.shades || [])
    .map(function (shade) { return (shade.images && shade.images[0]) || null; })
    .filter(Boolean);
%>
<article class="product-card reveal">
  <% if (product.badge) { %><span class="badge"><%= product.badge %></span><% } %>
  <button type="button" class="wishlist-btn"
          data-id="<%= product.id %>"
          data-name="<%= product.name %>"
          data-price="<%= product.effectivePrice %>"
          data-emoji="<%= product.emoji %>"
          data-tone="<%= product.tone %>"
          data-image="<%= (product.images && product.images[0]) || '' %>"
          data-stock="<%= product.stock %>"
          data-has-shades="<%= product.shades && product.shades.length ? '1' : '' %>"
          aria-label="Save <%= product.name %> to wishlist" aria-pressed="false"><%- icon('heart') %></button>
  <a href="/product/<%= product.id %>" class="product-art" style="--tone: <%= product.tone %>;" aria-label="<%= product.name %>">
    <% if (product.images && product.images.length) { %>
      <img class="art-photo" src="<%= (cardShadePhotos[0]) || product.images[0] %>" alt="<%= product.name %>" loading="lazy"
           <% if (cardShadePhotos.length > 1) { %>data-shade-photos='<%- JSON.stringify(cardShadePhotos) %>'<% } %>>
    <% } else if (product.emoji) { %>
      <span class="art-emoji"><%= product.emoji %></span>
    <% } else { %>
      <span class="art-emoji"><%- icon('bottle') %></span>
    <% } %>
  </a>
  <div class="product-card-body">
    <span class="product-brand"><%= product.brand %></span>
    <h3><a href="/product/<%= product.id %>"><%= product.name %></a></h3>
    <% if (product.reviewCount) { %>
      <%- include('stars', { rating: product.rating, count: product.reviewCount }) %>
    <% } else { %>
      <span class="stars-empty">No reviews yet</span>
    <% } %>
    <% if (product.shades && product.shades.length) { %>
      <div class="card-shade-dots">
        <% product.shades.slice(0, 6).forEach(function (shade) { %>
          <a href="/product/<%= product.id %>?shade=<%= encodeURIComponent(shade.name) %>" class="shade-dot <%= shade.soldOut ? 'is-sold-out' : '' %>"
             style="background-color: <%= shade.color %>;" title="<%= shade.label %><%= shade.soldOut ? ' (Sold out)' : '' %>" aria-label="<%= shade.label %>"></a>
        <% }); %>
        <% if (product.shades.length > 6) { %><span class="shade-dot-more">+<%= product.shades.length - 6 %></span><% } %>
      </div>
    <% } %>
    <p class="product-desc"><%= product.description %></p>
    <div class="product-card-foot">
      <span class="price-group">
        <% if (product.onSale) { %>
          <span class="price-original"><%= money(product.price) %></span>
          <span class="price price-sale"><%= money(product.salePrice) %></span>
          <span class="badge-sale">-<%= product.discountPercent %>%</span>
        <% } else { %>
          <span class="price"><%= money(product.price) %></span>
        <% } %>
        <% if (product.available && product.stock <= 5) { %>
          <span class="stock-pill stock-low">Only <%= product.stock %> left</span>
        <% } %>
      </span>
      <% if (!product.available) { %>
        <span class="stock-pill stock-out">Sold out</span>
      <% } else if (product.shades && product.shades.length) { %>
        <a class="btn btn-soft btn-sm" href="/product/<%= product.id %>">Choose a shade</a>
      <% } else { %>
        <button class="btn btn-primary btn-sm add-to-cart" type="button"
                data-id="<%= product.id %>"
                data-name="<%= product.name %>"
                data-price="<%= product.effectivePrice %>"
                data-emoji="<%= product.emoji %>"
                data-tone="<%= product.tone %>"
                data-stock="<%= product.stock %>">Add to bag</button>
      <% } %>
    </div>
  </div>
</article>
