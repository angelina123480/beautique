<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body data-signed-in="<%= user ? '1' : '' %>">
  <%- include('partials/header') %>

  <section class="container" style="padding-top: 44px;" id="product-page" data-product-id="<%= product.id %>">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a><span class="sep">/</span>
      <a href="/shop">Shop</a><span class="sep">/</span>
      <a href="/shop?category=<%= product.category %>" style="text-transform: capitalize;"><%= product.category %></a><span class="sep">/</span>
      <span><%= product.name %></span>
    </nav>

    <div class="product-layout">
      <div id="pdp-visual">
        <% if (product.images && product.images.length) { %>
          <div class="gallery-main" id="gallery-main" data-wink-map='<%- JSON.stringify(product.winkMap || {}) %>'>
            <img id="gallery-main-img" src="<%= product.images[0] %>" alt="<%= product.name %>" style="width:100%; display:block; aspect-ratio:1/1; object-fit:cover;">
            <img id="gallery-wink-overlay" class="gallery-wink-overlay" alt="">
            <button type="button" class="gallery-arrow gallery-arrow-prev" id="gallery-prev" aria-label="Previous photo">‹</button>
            <button type="button" class="gallery-arrow gallery-arrow-next" id="gallery-next" aria-label="Next photo">›</button>
          </div>
          <div class="gallery-thumbs" id="gallery-thumbs" data-images='<%- JSON.stringify(product.images || []) %>'></div>
        <% } else { %>
          <div class="product-art gallery-main" id="product-art" style="--tone: <%= product.tone %>;">
            <span class="art-emoji" style="font-size: clamp(80px, 14vw, 130px);"><%- product.emoji ? product.emoji : icon('bottle') %></span>
          </div>
        <% } %>
      </div>

      <div class="pdp-info">
        <% if (product.badge) { %><span class="badge badge-gold"><%= product.badge %></span><% } %>
        <h1><%= product.name %></h1>
        <span class="product-brand">By <%= product.brand %> · <span style="text-transform: capitalize;"><%= product.category %></span></span>
        <div style="margin-top: 10px;">
          <% if (product.reviewCount) { %>
            <%- include('partials/stars', { rating: product.rating, count: product.reviewCount }) %>
          <% } else { %>
            <span class="text-muted" style="font-size: 13.5px;">No reviews yet</span>
          <% } %>
        </div>

        <span class="price-group">
          <% if (product.onSale) { %>
            <span class="price-original" style="font-size: 20px;"><%= money(product.price) %></span>
            <span class="price price-sale" style="font-size: 30px;"><%= money(product.salePrice) %></span>
            <span class="badge-sale">-<%= product.discountPercent %>%</span>
          <% } else { %>
            <span class="price" style="font-size: 30px;"><%= money(product.price) %></span>
          <% } %>
          <small class="text-muted">· free shipping over $50</small>
        </span>

        <% if (!product.available) { %>
          <span class="stock-pill stock-out">Sold out</span>
        <% } else if (product.stock <= 5) { %>
          <span class="stock-pill stock-low">Only <%= product.stock %> left</span>
        <% } else { %>
          <span class="stock-pill stock-in"><%= product.stock %> in stock</span>
        <% } %>
        <% if (product.shades && product.shades.length) { %>
          <span class="stock-pill stock-neutral"><%= product.shades.length %> shade<%= product.shades.length === 1 ? '' : 's' %> available</span>
        <% } %>

        <p style="margin-top: 18px; color: var(--ink-soft); line-height: 1.75;"><%= product.description %></p>

        <% if (product.shades && product.shades.length) { %>
          <div class="field" style="margin-top: 18px;">
            <label>Shade <span id="shade-label" class="text-muted" style="font-weight: 400;"><%= product.selectedShade ? '— ' + product.selectedShade.label + (product.selectedShade.soldOut ? ' (Sold out)' : '') : '' %></span></label>
            <div class="shade-swatches" id="shade-swatches">
              <% product.shades.forEach(function(shade) { %>
                <button type="button" class="shade-swatch <%= (product.selectedShade && shade.name === product.selectedShade.name) ? 'is-active' : '' %> <%= shade.soldOut ? 'is-sold-out' : '' %>" style="background-color: <%= shade.color %>;" data-name="<%= shade.name %>" data-label="<%= shade.label %>" data-color="<%= shade.color %>" data-images='<%- JSON.stringify(shade.images || []) %>' data-stock="<%= shade.stock %>" data-sold-out="<%= shade.soldOut ? '1' : '' %>" aria-label="<%= shade.label %><%= shade.soldOut ? ' (Sold out)' : '' %>" title="<%= shade.label %><%= shade.soldOut ? ' (Sold out)' : '' %>"></button>
              <% }); %>
            </div>
            <a href="/shade-matcher" class="link-more" style="margin-top: 8px; display: inline-block;">Not sure which shade? Find your match →</a>
          </div>
        <% } %>

        <div class="pdp-actions">
          <% if (product.available) { %>
            <div class="qty-stepper" id="pdp-qty">
              <button type="button" id="pdp-qty-minus" aria-label="Decrease quantity">−</button>
              <span class="qty-val" id="pdp-qty-val">1</span>
              <button type="button" id="pdp-qty-plus" aria-label="Increase quantity">+</button>
            </div>
            <button class="btn btn-primary add-to-cart" type="button" id="pdp-add"
                    data-id="<%= product.id %>"
                    data-name="<%= product.name %>"
                    data-price="<%= product.effectivePrice %>"
                    data-emoji="<%= product.emoji %>"
                    data-tone="<%= product.tone %>"
                    data-stock="<%= product.selectedShade ? product.selectedShade.stock : product.stock %>"
                    data-shade="<%= product.selectedShade ? product.selectedShade.name : '' %>"
                    <%= (product.selectedShade && product.selectedShade.soldOut) ? 'disabled' : '' %>><%= (product.selectedShade && product.selectedShade.soldOut) ? 'This shade is sold out' : 'Add to bag — ' + money(product.effectivePrice) %></button>
          <% } else { %>
            <button class="btn btn-primary" disabled>Sold out</button>
            <a class="btn btn-ghost" href="/shop">Browse alternatives</a>
          <% } %>
          <button type="button" class="wishlist-btn wishlist-btn-pdp"
                  data-id="<%= product.id %>"
                  data-name="<%= product.name %>"
                  data-price="<%= product.effectivePrice %>"
                  data-emoji="<%= product.emoji %>"
                  data-tone="<%= product.tone %>"
                  data-image="<%= (product.images && product.images[0]) || '' %>"
                  data-stock="<%= product.stock %>"
                  data-has-shades="<%= product.shades && product.shades.length ? '1' : '' %>"
                  aria-label="Save <%= product.name %> to wishlist" aria-pressed="false"><%- icon('heart') %></button>
        </div>

        <div class="accordion">
          <div class="accordion-item is-open">
            <button type="button" class="accordion-trigger" aria-expanded="true">
              <span>Why you'll love it</span>
              <span class="accordion-icon">+</span>
            </button>
            <div class="accordion-panel">
              <div class="accordion-panel-inner">
                <div class="accordion-body"><%= product.description %> Designed to layer beautifully with the rest of your Beautique ritual.</div>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <button type="button" class="accordion-trigger" aria-expanded="false">
              <span>Shipping &amp; returns</span>
              <span class="accordion-icon">+</span>
            </button>
            <div class="accordion-panel">
              <div class="accordion-panel-inner">
                <div class="accordion-body">Free tracked shipping on orders over $50 (otherwise $5.95). Unopened products can be returned within 30 days for a full refund.</div>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <button type="button" class="accordion-trigger" aria-expanded="false">
              <span>Our promise</span>
              <span class="accordion-icon">+</span>
            </button>
            <div class="accordion-panel">
              <div class="accordion-panel-inner">
                <div class="accordion-body">Every Beautique formula is vegan, cruelty-free, and made in small batches with skin-kind ingredients.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="section" id="reviews">
      <div class="section-head">
        <div>
          <span class="eyebrow">What people say</span>
          <h2>Reviews</h2>
        </div>
      </div>

      <div class="grid grid-2" style="align-items: start;">
        <div class="card reveal">
          <% if (reviews.length) { %>
            <div class="review-summary-box">
              <span class="big-score"><%= product.rating %></span>
              <div>
                <%- include('partials/stars', { rating: product.rating }) %>
                <p class="text-muted" style="margin: 4px 0 0; font-size: 13.5px;">Based on <%= product.reviewCount %> review<%= product.reviewCount === 1 ? '' : 's' %></p>
              </div>
            </div>
            <div id="review-list">
              <% reviews.forEach(function(review) { %>
                <div class="review-item" data-review data-review-id="<%= review.id %>">
                  <div class="review-item-head">
                    <strong><%= review.userName %></strong>
                    <span class="stars"><%- '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating) %></span>
                    <% if (review.verified) { %><span class="verified-tag">✓ Verified purchase</span><% } %>
                    <span class="review-date"><%= dateLabel(review.createdAt) %></span>
                  </div>
                  <p class="review-comment-view" style="<%= review.comment ? '' : 'display:none;' %>"><%= review.comment %></p>
                  <% if (user && review.userId === user.id) { %>
                    <textarea class="review-comment-edit" style="display:none;"><%= review.comment %></textarea>
                    <div class="table-actions" style="margin-top: 8px;">
                      <button class="btn btn-soft btn-sm" data-own-review-edit type="button">Edit</button>
                      <button class="btn btn-primary btn-sm" data-own-review-save type="button" style="display:none;">Save</button>
                      <button class="btn btn-ghost btn-sm" data-own-review-cancel type="button" style="display:none;">Cancel</button>
                      <button class="btn btn-danger btn-sm" data-own-review-delete type="button">Delete</button>
                    </div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="empty-state" style="padding: 40px 10px;">
              <span class="empty-emoji"><%- icon('message') %></span>
              <h3>No reviews yet</h3>
              <p>Be the first to share your experience.</p>
            </div>
          <% } %>
        </div>

        <div class="card reveal" style="transition-delay: 0.08s;">
          <h3 style="font-size: 22px;">Write a review</h3>
          <% if (user) { %>
            <form id="review-form">
              <div class="field">
                <label>Your rating</label>
                <div class="star-picker" id="star-picker">
                  <span data-value="1">★</span><span data-value="2">★</span><span data-value="3">★</span><span data-value="4">★</span><span data-value="5">★</span>
                </div>
                <input type="hidden" id="review-rating" value="5">
              </div>
              <div class="field">
                <label for="review-comment">Your review</label>
                <textarea id="review-comment" placeholder="What did you like? How does it feel?"></textarea>
              </div>
              <button class="btn btn-primary" type="submit">Submit review</button>
              <div class="form-status" id="review-status"></div>
            </form>
          <% } else { %>
            <p class="text-muted">Sign in to share your experience with this product.</p>
            <a class="btn btn-soft" href="/auth">Sign in to review</a>
          <% } %>
        </div>
      </div>
    </div>

    <% if (frequentlyBought.length) { %>
      <div style="padding-bottom: 40px;">
        <div class="section-head">
          <div>
            <span class="eyebrow">Pairs well together</span>
            <h2>Frequently bought together</h2>
          </div>
        </div>
        <div class="grid grid-3">
          <% frequentlyBought.forEach(function(product) { %>
            <%- include('partials/product-card', { product: product }) %>
          <% }); %>
        </div>
      </div>
    <% } %>

    <% if (related.length) { %>
      <div style="padding-bottom: 40px;">
        <div class="section-head">
          <div>
            <span class="eyebrow">Keep exploring</span>
            <h2>You may also love</h2>
          </div>
        </div>
        <div class="grid grid-3">
          <% related.forEach(function(product) { %>
            <%- include('partials/product-card', { product: product }) %>
          <% }); %>
        </div>
      </div>
    <% } %>

    <section id="recently-viewed" data-exclude-id="<%= product.id %>" style="display:none; padding-bottom: 40px;">
      <div class="section-head">
        <div><h2>Recently viewed</h2></div>
      </div>
      <div class="grid grid-3" id="recently-viewed-grid"></div>
    </section>
  </section>

  <%- include('partials/footer', { pageScript: 'product' }) %>
  <script src="/javascripts/recently-viewed.js?v=<%= assetVersion('javascripts/recently-viewed.js') %>"></script>
</body>
</html>
