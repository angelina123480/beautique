<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="container page-head">
    <span class="eyebrow">My account</span>
    <h1>Hello, <%= user.name.split(' ')[0] %></h1>
    <p class="lead">Manage your details and keep an eye on your orders.</p>
  </div>

  <section class="container" style="padding-bottom: 60px;">
    <div class="grid grid-2" style="align-items: start;">
      <div>
      <div class="card" style="margin-bottom: 20px;">
        <h3 style="font-size: 22px;">Your information</h3>
        <form id="profile-form">
          <div class="field">
            <label for="profile-name">Full name</label>
            <input id="profile-name" type="text" value="<%= user.name %>" autocomplete="name">
          </div>
          <div class="field">
            <label for="profile-email">Email address</label>
            <input id="profile-email" type="email" value="<%= user.email %>" autocomplete="email">
          </div>
          <div class="field-row">
            <div class="field">
              <label for="profile-phone">Phone</label>
              <input id="profile-phone" type="tel" value="<%= user.phone %>" autocomplete="tel" placeholder="+1 …">
            </div>
            <div class="field">
              <label for="profile-address">Delivery address</label>
              <input id="profile-address" type="text" value="<%= user.address %>" autocomplete="street-address" placeholder="Street, city, country">
            </div>
          </div>
          <button class="btn btn-primary" type="submit">Save changes</button>
          <div class="form-status" id="profile-status"></div>
        </form>
        <hr class="divider">
        <div style="display:flex; gap: 10px; flex-wrap: wrap;">
          <% if (user.role === 'admin') { %>
            <a class="btn btn-dark btn-sm" href="/admin">Open admin dashboard</a>
          <% } %>
          <button class="btn btn-ghost btn-sm" id="signout-button" type="button">Sign out</button>
        </div>

        <hr class="divider">
        <div id="danger-zone">
          <h4 style="color: var(--danger); font-size: 15px; margin: 0 0 4px;">Danger zone</h4>
          <p class="text-muted" style="font-size: 13.5px; margin-bottom: 12px;">Permanently delete your account and all its data. This cannot be undone.</p>
          <button class="btn btn-ghost btn-sm" id="delete-account-open" type="button" style="color: var(--danger); border-color: var(--danger-soft);">Delete my account</button>

          <form id="delete-account-form" style="display:none; margin-top: 14px;">
            <div class="field">
              <label for="delete-account-password">Confirm your password to continue</label>
              <div class="password-field">
                <input id="delete-account-password" type="password" placeholder="••••••••" autocomplete="current-password">
                <button type="button" class="password-toggle" data-target="delete-account-password" aria-label="Show password"><%- icon('eye') %></button>
              </div>
            </div>
            <div style="display:flex; gap: 10px;">
              <button class="btn btn-danger btn-sm" type="submit">Permanently delete my account</button>
              <button class="btn btn-ghost btn-sm" id="delete-account-cancel" type="button">Cancel</button>
            </div>
            <div class="form-status" id="delete-account-status"></div>
          </form>
        </div>
      </div>

      <div class="card" id="rewards-card">
        <h3 style="font-size: 22px;">Rewards</h3>
        <p class="text-muted" style="font-size: 13.5px;">Earn 1 point for every $1 you spend. Unlock a tier and redeem it for a discount at checkout.</p>
        <div class="rewards-points"><strong><%= user.rewardPoints %></strong> <span class="text-muted">points</span></div>
        <div class="rewards-tiers">
          <% rewardTiers.forEach(function(tier) { %>
            <% var redeemed = user.redeemedTiers.indexOf(tier.threshold) !== -1; %>
            <% var unlocked = user.rewardPoints >= tier.threshold; %>
            <div class="rewards-tier <%= redeemed ? 'is-redeemed' : (unlocked ? 'is-unlocked' : 'is-locked') %>">
              <div><strong><%= tier.threshold %> pts</strong> <span class="text-muted">— <%= tier.discount %>% off</span></div>
              <span class="badge <%= unlocked && !redeemed ? 'badge-gold' : '' %>"><%= redeemed ? 'Redeemed' : (unlocked ? 'Ready to redeem' : 'Locked') %></span>
            </div>
          <% }); %>
        </div>
      </div>
      </div>

      <div class="card">
        <h3 style="font-size: 22px;">Your orders</h3>
        <div id="orders-list"><p class="text-muted">Loading your orders…</p></div>
      </div>
    </div>

    <div class="card" style="margin-top: 24px;">
      <h3 style="font-size: 22px;">Your saved shades</h3>
      <p class="text-muted" style="font-size: 13.5px;">Skin tone shifts with the seasons for a lot of people — save a summer and a winter reading here for a more accurate match year-round.</p>
      <div id="saved-shades-list"></div>

      <hr class="divider">

      <h4 style="font-size: 16px; margin-bottom: 10px;">Save a new reading</h4>
      <div class="grid grid-2" style="align-items: start; gap: 24px;">
        <div>
          <div class="matcher-season-picker" id="profile-season-picker">
            <button type="button" class="matcher-season-btn is-active" data-season="summer">☀️ Summer shade</button>
            <button type="button" class="matcher-season-btn" data-season="winter">❄️ Winter shade</button>
          </div>

          <div class="matcher-tabs">
            <button type="button" class="matcher-tab is-active" data-matcher-tab="upload">Upload photo</button>
            <button type="button" class="matcher-tab" data-matcher-tab="webcam">Use webcam</button>
          </div>

          <div id="profile-shade-panel-upload" class="matcher-panel">
            <input type="file" id="profile-shade-file-input" accept="image/*" style="display:none;">
            <button type="button" class="btn btn-soft btn-block" id="profile-shade-upload-btn">Choose a photo…</button>
          </div>

          <div id="profile-shade-panel-webcam" class="matcher-panel" style="display:none;">
            <button type="button" class="btn btn-soft btn-block" id="profile-shade-webcam-start">Turn on webcam</button>
            <button type="button" class="btn btn-primary btn-block" id="profile-shade-webcam-capture" style="display:none; margin-top:10px;">Capture photo</button>
          </div>

          <p class="text-muted" style="font-size: 12px;">Stored only in your browser's local storage — never uploaded or sent to our servers.</p>
        </div>

        <div>
          <div class="matcher-frame" id="profile-shade-frame">
            <video id="profile-shade-video" playsinline muted style="display:none;"></video>
            <canvas id="profile-shade-canvas" style="display:none;"></canvas>
            <div class="matcher-placeholder" id="profile-shade-placeholder">
              <%- icon('user') %>
              <span>Your photo will appear here</span>
            </div>
          </div>
          <div class="matcher-status" id="profile-shade-status" role="status"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- face-api.js: free, MIT-licensed, runs entirely client-side (no API keys,
       no server calls) — needed here so shades can be captured and saved
       directly from the profile page, not just on /shade-matcher. -->
  <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
  <script src="/javascripts/color-science.js?v=<%= assetVersion('javascripts/color-science.js') %>"></script>
  <script src="/javascripts/skin-sampler.js?v=<%= assetVersion('javascripts/skin-sampler.js') %>"></script>

  <%- include('partials/footer', { pageScript: 'profile' }) %>
</body>
</html>
