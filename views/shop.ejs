<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="container page-head">
    <span class="eyebrow">Shop the collection</span>
    <h1>Everything for your everyday glow.</h1>
    <p class="lead">Makeup, skincare, and scent — each one picked because it earns a place in your routine, not just your cart.</p>
  </div>

  <section class="container" style="padding-bottom: 72px;">
    <% var qsSort = activeSort !== 'featured' ? '&sort=' + activeSort : ''; %>
    <% var qsSearch = searchTerm ? '&search=' + encodeURIComponent(searchTerm) : ''; %>
    <% var qsPrice = activePrice ? '&price=' + activePrice : ''; %>
    <% var qsRating = activeRating ? '&rating=' + activeRating : ''; %>
    <% var qsInStock = activeInStock ? '&inStock=1' : ''; %>
    <% var qsOnSale = activeOnSale ? '&onSale=1' : ''; %>
    <% var qsBrand = activeBrand ? '&brand=' + encodeURIComponent(activeBrand) : ''; %>
    <% var qsScent = activeScentFamily ? '&scentFamily=' + activeScentFamily : ''; %>
    <% var qsSkin = activeSkinGoal ? '&skinGoal=' + activeSkinGoal : ''; %>
    <% var qsExtra = qsSort + qsSearch + qsPrice + qsRating + qsInStock + qsOnSale + qsBrand + qsScent + qsSkin; %>

    <div class="shop-toolbar">
      <form class="search-box" id="shop-search-form" method="get" action="/shop">
        <input type="text" name="search" id="shop-search-input" placeholder="Search products, brands…" value="<%= searchTerm %>">
        <% if (activeCategory) { %><input type="hidden" name="category" value="<%= activeCategory %>"><% } %>
        <% if (activeSort !== 'featured') { %><input type="hidden" name="sort" value="<%= activeSort %>"><% } %>
        <% if (activePrice) { %><input type="hidden" name="price" value="<%= activePrice %>"><% } %>
        <% if (activeRating) { %><input type="hidden" name="rating" value="<%= activeRating %>"><% } %>
        <% if (activeInStock) { %><input type="hidden" name="inStock" value="1"><% } %>
        <% if (activeOnSale) { %><input type="hidden" name="onSale" value="1"><% } %>
        <% if (activeBrand) { %><input type="hidden" name="brand" value="<%= activeBrand %>"><% } %>
        <% if (activeScentFamily) { %><input type="hidden" name="scentFamily" value="<%= activeScentFamily %>"><% } %>
        <% if (activeSkinGoal) { %><input type="hidden" name="skinGoal" value="<%= activeSkinGoal %>"><% } %>
        <button type="submit" aria-label="Search"><%- icon('search') %></button>
      </form>

      <div class="chip-row">
        <a class="chip <%= !activeCategory ? 'is-active' : '' %>" href="/shop?<%= qsExtra.replace(/^&/, '') %>">All</a>
        <% categories.forEach(function(category) { %>
          <a class="chip <%= activeCategory === category.id ? 'is-active' : '' %>"
             href="/shop?category=<%= category.id %><%= qsExtra %>"><%- categoryIcon(category.id) %> <%= category.title %></a>
        <% }); %>
      </div>

      <form method="get" action="/shop" id="shop-sort-form">
        <% if (activeCategory) { %><input type="hidden" name="category" value="<%= activeCategory %>"><% } %>
        <% if (searchTerm) { %><input type="hidden" name="search" value="<%= searchTerm %>"><% } %>
        <% if (activePrice) { %><input type="hidden" name="price" value="<%= activePrice %>"><% } %>
        <% if (activeRating) { %><input type="hidden" name="rating" value="<%= activeRating %>"><% } %>
        <% if (activeInStock) { %><input type="hidden" name="inStock" value="1"><% } %>
        <% if (activeOnSale) { %><input type="hidden" name="onSale" value="1"><% } %>
        <% if (activeBrand) { %><input type="hidden" name="brand" value="<%= activeBrand %>"><% } %>
        <% if (activeScentFamily) { %><input type="hidden" name="scentFamily" value="<%= activeScentFamily %>"><% } %>
        <% if (activeSkinGoal) { %><input type="hidden" name="skinGoal" value="<%= activeSkinGoal %>"><% } %>
        <select class="select-pill" name="sort" id="shop-sort" aria-label="Sort products">
          <option value="featured" <%= activeSort === 'featured' ? 'selected' : '' %>>Sort: Featured</option>
          <option value="price-asc" <%= activeSort === 'price-asc' ? 'selected' : '' %>>Price: low → high</option>
          <option value="price-desc" <%= activeSort === 'price-desc' ? 'selected' : '' %>>Price: high → low</option>
          <option value="rating" <%= activeSort === 'rating' ? 'selected' : '' %>>Top rated</option>
          <option value="name" <%= activeSort === 'name' ? 'selected' : '' %>>Name A–Z</option>
        </select>
      </form>
    </div>

    <form method="get" action="/shop" id="shop-filters-form" class="filter-row">
      <% if (activeCategory) { %><input type="hidden" name="category" value="<%= activeCategory %>"><% } %>
      <% if (searchTerm) { %><input type="hidden" name="search" value="<%= searchTerm %>"><% } %>
      <% if (activeSort !== 'featured') { %><input type="hidden" name="sort" value="<%= activeSort %>"><% } %>

      <select class="select-pill" name="price" id="shop-filter-price" aria-label="Filter by price">
        <option value="">Any price</option>
        <option value="under25" <%= activePrice === 'under25' ? 'selected' : '' %>>Under $25</option>
        <option value="25-50" <%= activePrice === '25-50' ? 'selected' : '' %>>$25 – $50</option>
        <option value="50-100" <%= activePrice === '50-100' ? 'selected' : '' %>>$50 – $100</option>
        <option value="over100" <%= activePrice === 'over100' ? 'selected' : '' %>>Over $100</option>
      </select>

      <select class="select-pill" name="rating" id="shop-filter-rating" aria-label="Filter by rating">
        <option value="">Any rating</option>
        <option value="4" <%= activeRating === '4' ? 'selected' : '' %>>4★ &amp; up</option>
        <option value="3" <%= activeRating === '3' ? 'selected' : '' %>>3★ &amp; up</option>
      </select>

      <select class="select-pill" name="brand" id="shop-filter-brand" aria-label="Filter by brand">
        <option value="">Any brand</option>
        <% brands.forEach(function(b) { %>
          <option value="<%= b %>" <%= activeBrand === b ? 'selected' : '' %>><%= b %></option>
        <% }); %>
      </select>

      <% if (!activeCategory || activeCategory === 'fragrance') { %>
        <select class="select-pill" name="scentFamily" id="shop-filter-scent" aria-label="Filter by scent family">
          <option value="">Any scent</option>
          <% scentFamilies.forEach(function(s) { %>
            <option value="<%= s.id %>" <%= activeScentFamily === s.id ? 'selected' : '' %>><%= s.label %></option>
          <% }); %>
        </select>
      <% } %>

      <% if (!activeCategory || activeCategory === 'skincare') { %>
        <select class="select-pill" name="skinGoal" id="shop-filter-skin" aria-label="Filter by skin goal">
          <option value="">Any skin goal</option>
          <% skinGoals.forEach(function(s) { %>
            <option value="<%= s.id %>" <%= activeSkinGoal === s.id ? 'selected' : '' %>><%= s.label %></option>
          <% }); %>
        </select>
      <% } %>

      <label class="filter-check">
        <input type="checkbox" name="inStock" id="shop-filter-instock" value="1" <%= activeInStock ? 'checked' : '' %>>
        In stock only
      </label>

      <label class="filter-check">
        <input type="checkbox" name="onSale" id="shop-filter-onsale" value="1" <%= activeOnSale ? 'checked' : '' %>>
        On sale only
      </label>

      <% if (activePrice || activeRating || activeInStock || activeOnSale || activeBrand || activeScentFamily || activeSkinGoal) { %>
        <% var keepParams = []; %>
        <% if (activeCategory) { keepParams.push('category=' + activeCategory); } %>
        <% if (searchTerm) { keepParams.push('search=' + encodeURIComponent(searchTerm)); } %>
        <% if (activeSort !== 'featured') { keepParams.push('sort=' + activeSort); } %>
        <a class="link-more" href="/shop<%= keepParams.length ? '?' + keepParams.join('&') : '' %>">Clear filters</a>
      <% } %>
    </form>

    <% if (searchTerm) { %>
      <p class="text-muted" style="margin-bottom: 22px;"><%= products.length %> result<%= products.length === 1 ? '' : 's' %> for “<%= searchTerm %>”</p>
    <% } %>

    <% if (activeCategory === 'makeup') { %>
      <a href="/shade-matcher" class="quiz-teaser reveal" style="margin-bottom: 28px; padding: 24px 28px;">
        <div>
          <span class="eyebrow">2-minute quiz</span>
          <h3 style="font-size: 19px;">Not sure which shade is yours?</h3>
          <p style="font-size: 13.5px;">Use our shade matcher for a personalized match, then shop it directly.</p>
        </div>
        <span class="btn btn-primary btn-sm">Find your shade →</span>
      </a>
    <% } %>

    <% if (activeCategory === 'fragrance') { %>
      <a href="/fragrance-quiz" class="quiz-teaser reveal" style="margin-bottom: 28px; padding: 24px 28px;">
        <div>
          <span class="eyebrow">2-minute quiz</span>
          <h3 style="font-size: 19px;">Not sure which scent is you?</h3>
          <p style="font-size: 13.5px;">Take our scent quiz for a personalized match.</p>
        </div>
        <span class="btn btn-primary btn-sm">Take the quiz →</span>
      </a>
    <% } %>

    <% if (activeCategory === 'skincare') { %>
      <a href="/skincare-quiz" class="quiz-teaser reveal" style="margin-bottom: 28px; padding: 24px 28px;">
        <div>
          <span class="eyebrow">2-minute quiz</span>
          <h3 style="font-size: 19px;">Not sure which product is right for you?</h3>
          <p style="font-size: 13.5px;">Take our skincare quiz for a goal-based recommendation.</p>
        </div>
        <span class="btn btn-primary btn-sm">Take the quiz →</span>
      </a>
    <% } %>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <span class="empty-emoji"><%- icon('search') %></span>
        <h3>No products found</h3>
        <p>Try a different search, or browse a brand like Luna, Aura, or Nova.</p>
        <a class="btn btn-soft" href="/shop">Clear filters</a>
      </div>
    <% } else { %>
      <div class="grid grid-3">
        <% products.forEach(function(product) { %>
          <%- include('partials/product-card', { product: product }) %>
        <% }); %>
      </div>
    <% } %>

    <section id="recommended-for-you" style="display:none; margin-top: 56px;">
      <h2 style="font-size: 22px; margin-bottom: 20px;">Recommended for you</h2>
      <div class="grid grid-3" id="recommended-for-you-grid"></div>
    </section>

    <section id="recently-viewed" style="display:none; margin-top: 56px;">
      <h2 style="font-size: 22px; margin-bottom: 20px;">Recently viewed</h2>
      <div class="grid grid-3" id="recently-viewed-grid"></div>
    </section>
  </section>

  <%- include('partials/footer', { pageScript: 'shop' }) %>
  <script src="/javascripts/recently-viewed.js?v=<%= assetVersion('javascripts/recently-viewed.js') %>"></script>
  <script src="/javascripts/recommended.js?v=<%= assetVersion('javascripts/recommended.js') %>"></script>
</body>
</html>
